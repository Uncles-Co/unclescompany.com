---
interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
  accentColor: string;
}

const { features, accentColor } = Astro.props;
---

<div class="feature-grid">
  {features.map((feature) => (
    <div class="feature-item">
      <div class="feature-item__icon" style={`background: ${accentColor}20; color: ${accentColor};`}>
        {feature.icon}
      </div>
      <h4 class="feature-item__title">{feature.title}</h4>
      <p class="feature-item__desc">{feature.description}</p>
    </div>
  ))}
</div>
