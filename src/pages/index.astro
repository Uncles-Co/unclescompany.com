---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
---

<Base title="Uncles&Co — Software empresarial hecho en Ecuador">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero__title fade-in">
        Software empresarial<br /><span class="gradient-text">hecho en Ecuador</span>
      </h1>
      <p class="hero__subtitle fade-in fade-in-delay-1">
        Un ecosistema completo de herramientas para gestionar tu empresa: recursos humanos, contabilidad, manufactura. Todo integrado, todo local.
      </p>
      <div class="hero__actions fade-in fade-in-delay-2">
        <a href="/contacto" class="btn btn-primary btn-lg">Solicitar demo</a>
        <a href="/#productos" class="btn btn-secondary btn-lg">Ver productos</a>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="section" id="productos">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Nuestros productos</h2>
        <p>Tres soluciones especializadas que trabajan juntas para cubrir todas las necesidades de tu empresa.</p>
      </div>

      <div class="grid grid-3 fade-in fade-in-delay-1">
        <ProductCard
          name="Core"
          tagline="Sistema de recursos humanos y nomina ecuatoriana. Gestiona tu talento humano de principio a fin."
          href="/core"
          accentColor="#534AB7"
          initial="C"
        />
        <ProductCard
          name="Vault"
          tagline="ERP completo con facturacion electronica SRI, contabilidad NIIF, inventarios y mas."
          href="/vault"
          accentColor="#2563EB"
          initial="V"
        />
        <ProductCard
          name="Arch"
          tagline="Gestion de manufactura y procesamiento de madera. Trazabilidad completa desde recepcion hasta exportacion."
          href="/arch"
          accentColor="#059669"
          initial="A"
        />
      </div>
    </div>
  </section>

  <!-- Why Uncles&Co -->
  <section class="section-sm">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Por que Uncles&Co</h2>
      </div>

      <div class="grid grid-4 fade-in fade-in-delay-1">
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h4 class="value-card__title">Compliance Ecuador nativo</h4>
          <p class="value-card__desc">IESS, SRI, MRL, NIIF. Nuestro software nace con las regulaciones ecuatorianas integradas, no adaptadas.</p>
        </div>

        <div class="value-card">
          <div class="value-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </div>
          <h4 class="value-card__title">Ecosistema integrado</h4>
          <p class="value-card__desc">HR, ERP y manufactura conectados. Comparte datos entre productos sin duplicar trabajo.</p>
        </div>

        <div class="value-card">
          <div class="value-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4c0 2 1.5 3.5 3 5l1 1 1-1c1.5-1.5 3-3 3-5a4 4 0 0 0-4-4z"/><path d="M5 20c0-3 2-5 7-5s7 2 7 5"/></svg>
          </div>
          <h4 class="value-card__title">AI incorporado</h4>
          <p class="value-card__desc">Prediccion de rotacion, asistente contable inteligente y analytics avanzados. Tecnologia de punta, aplicada.</p>
        </div>

        <div class="value-card">
          <div class="value-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h4 class="value-card__title">Soporte local</h4>
          <p class="value-card__desc">Equipo ecuatoriano que entiende tu realidad. Soporte directo, implementacion guiada, sin intermediarios.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section">
    <div class="container">
      <div class="stats fade-in">
        <div>
          <div class="stat__number">4+</div>
          <div class="stat__label">Empresas activas</div>
        </div>
        <div>
          <div class="stat__number">3</div>
          <div class="stat__label">Productos</div>
        </div>
        <div>
          <div class="stat__number">100%</div>
          <div class="stat__label">Ecuador</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Custom Solutions -->
  <section class="section-sm">
    <div class="container">
      <div class="custom-solutions fade-in">
        <div class="custom-solutions__content">
          <div class="custom-solutions__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <div>
            <h3 class="custom-solutions__title">Tu empresa no encaja en una solucion estandar?</h3>
            <p class="custom-solutions__desc">Desarrollamos software a la medida para empresas con procesos unicos. Desde integraciones con sistemas existentes hasta modulos completamente personalizados — con la misma calidad y compliance de nuestros productos.</p>
          </div>
        </div>
        <a href="/contacto" class="btn btn-secondary">Conversemos sobre tu proyecto</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-section__box fade-in">
        <h2 class="cta-section__title">Listo para digitalizar tu empresa?</h2>
        <p class="cta-section__desc">Agenda una demo personalizada y descubre como Uncles&Co puede transformar tus operaciones.</p>
        <a href="/contacto" class="btn btn-primary btn-lg">Contactanos</a>
      </div>
    </div>
  </section>

</Base>
