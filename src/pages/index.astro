---
import Base from '../layouts/Base.astro';
import ProductCard from '../components/ProductCard.astro';
---

<Base title="Uncles&Co — Software empresarial hecho en Ecuador">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero__title fade-in">
        Software empresarial<br /><span class="gradient-text">hecho en Ecuador</span>
      </h1>
      <p class="hero__subtitle fade-in fade-in-delay-1">
        Un ecosistema completo de herramientas para gestionar tu empresa: recursos humanos, contabilidad, manufactura. Todo integrado, todo local.
      </p>
      <div class="hero__actions fade-in fade-in-delay-2">
        <a href="/contacto" class="btn btn-primary btn-lg">Solicitar demo</a>
        <a href="/#productos" class="btn btn-secondary btn-lg">Ver productos</a>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="section" id="productos">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Nuestros productos</h2>
        <p>Tres soluciones especializadas que trabajan juntas para cubrir todas las necesidades de tu empresa.</p>
      </div>

      <!-- Core -->
      <div class="product-showcase fade-in" style="--accent: #534AB7; --accent-glow: rgba(83,74,183,0.15);">
        <div class="product-showcase__info">
          <div class="product-showcase__badge">Core</div>
          <h3 class="product-showcase__title">Recursos Humanos y Nomina</h3>
          <p class="product-showcase__desc">Gestiona el ciclo completo del talento humano: desde la contratacion hasta la liquidacion, con nomina 100% ecuatoriana.</p>
          <ul class="product-showcase__features">
            <li>Nomina con IESS, SRI, fondos de reserva</li>
            <li>Portal de empleados self-service</li>
            <li>Evaluaciones 360 y OKRs</li>
            <li>AI: prediccion de rotacion</li>
          </ul>
          <a href="/core" class="btn btn-primary">Conocer Core</a>
        </div>
        <div class="product-showcase__preview">
          <div class="app-mockup" style="--accent: #534AB7;">
            <div class="app-mockup__topbar">
              <div class="app-mockup__dots"><span></span><span></span><span></span></div>
              <div class="app-mockup__url">core.unclescompany.com</div>
            </div>
            <div class="app-mockup__body">
              <div class="app-mockup__sidebar">
                <div class="app-mockup__logo">C<span>.</span></div>
                <div class="mock-nav-item active"></div>
                <div class="mock-nav-item"></div>
                <div class="mock-nav-item"></div>
                <div class="mock-nav-item"></div>
                <div class="mock-nav-item"></div>
              </div>
              <div class="app-mockup__content">
                <div class="mock-header"></div>
                <div class="mock-kpi-row">
                  <div class="mock-kpi" style="--kpi-color: #534AB7;"><div class="mock-kpi__value">48</div><div class="mock-kpi__label"></div></div>
                  <div class="mock-kpi" style="--kpi-color: #7C6FD4;"><div class="mock-kpi__value">$12.4k</div><div class="mock-kpi__label"></div></div>
                  <div class="mock-kpi" style="--kpi-color: #9B8FE8;"><div class="mock-kpi__value">2.1%</div><div class="mock-kpi__label"></div></div>
                </div>
                <div class="mock-chart">
                  <svg viewBox="0 0 200 60" class="mock-chart__svg">
                    <polyline points="0,45 30,38 60,42 90,30 120,25 150,28 180,15 200,18" fill="none" stroke="#534AB7" stroke-width="2"/>
                    <polyline points="0,45 30,38 60,42 90,30 120,25 150,28 180,15 200,18" fill="url(#coreFill)" stroke="none"/>
                    <defs><linearGradient id="coreFill" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#534AB7" stop-opacity="0.3"/><stop offset="100%" stop-color="#534AB7" stop-opacity="0"/></linearGradient></defs>
                  </svg>
                </div>
                <div class="mock-table">
                  <div class="mock-table__row header"></div>
                  <div class="mock-table__row"></div>
                  <div class="mock-table__row"></div>
                  <div class="mock-table__row"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Vault -->
      <div class="product-showcase product-showcase--reverse fade-in" style="--accent: #2563EB; --accent-glow: rgba(37,99,235,0.15);">
        <div class="product-showcase__info">
          <div class="product-showcase__badge">Vault</div>
          <h3 class="product-showcase__title">ERP y Facturacion Electronica</h3>
          <p class="product-showcase__desc">Contabilidad NIIF, facturacion SRI, inventarios, bancos, activos fijos y punto de venta. Todo en un solo lugar.</p>
          <ul class="product-showcase__features">
            <li>Facturacion electronica SRI con firma digital</li>
            <li>Contabilidad NIIF doble partida</li>
            <li>Inventarios multi-bodega con kardex</li>
            <li>AI: asistente contable VaultBot</li>
          </ul>
          <a href="/vault" class="btn btn-primary">Conocer Vault</a>
        </div>
        <div class="product-showcase__preview">
          <div class="app-mockup" style="--accent: #2563EB;">
            <div class="app-mockup__topbar">
              <div class="app-mockup__dots"><span></span><span></span><span></span></div>
              <div class="app-mockup__url">vault.unclescompany.com</div>
            </div>
            <div class="app-mockup__body">
              <div class="app-mockup__sidebar">
                <div class="app-mockup__logo">V<span>.</span></div>
                <div class="mock-nav-item active"></div>
                <div class="mock-nav-item"></div>
                <div class="mock-nav-item"></div>
                <div class="mock-nav-item"></div>
                <div class="mock-nav-item"></div>
              </div>
              <div class="app-mockup__content">
                <div class="mock-header"></div>
                <div class="mock-kpi-row">
                  <div class="mock-kpi" style="--kpi-color: #2563EB;"><div class="mock-kpi__value">$84k</div><div class="mock-kpi__label"></div></div>
                  <div class="mock-kpi" style="--kpi-color: #3B82F6;"><div class="mock-kpi__value">127</div><div class="mock-kpi__label"></div></div>
                  <div class="mock-kpi" style="--kpi-color: #60A5FA;"><div class="mock-kpi__value">98%</div><div class="mock-kpi__label"></div></div>
                </div>
                <div class="mock-chart">
                  <svg viewBox="0 0 200 60" class="mock-chart__svg">
                    <rect x="10" y="30" width="20" height="30" rx="2" fill="#2563EB" opacity="0.4"/>
                    <rect x="40" y="20" width="20" height="40" rx="2" fill="#2563EB" opacity="0.5"/>
                    <rect x="70" y="25" width="20" height="35" rx="2" fill="#2563EB" opacity="0.6"/>
                    <rect x="100" y="10" width="20" height="50" rx="2" fill="#2563EB" opacity="0.7"/>
                    <rect x="130" y="15" width="20" height="45" rx="2" fill="#2563EB" opacity="0.8"/>
                    <rect x="160" y="5" width="20" height="55" rx="2" fill="#2563EB" opacity="0.9"/>
                  </svg>
                </div>
                <div class="mock-table">
                  <div class="mock-table__row header"></div>
                  <div class="mock-table__row"></div>
                  <div class="mock-table__row"></div>
                  <div class="mock-table__row"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Arch -->
      <div class="product-showcase fade-in" style="--accent: #059669; --accent-glow: rgba(5,150,105,0.15);">
        <div class="product-showcase__info">
          <div class="product-showcase__badge">Arch</div>
          <h3 class="product-showcase__title">Manufactura y Trazabilidad</h3>
          <p class="product-showcase__desc">Control total del proceso productivo: recepcion de materia prima, secado, produccion, empaque y exportacion con trazabilidad QR.</p>
          <ul class="product-showcase__features">
            <li>Trazabilidad QR en cada etapa</li>
            <li>Control de secado en horno</li>
            <li>Contenedores y logistica export</li>
            <li>AI: asistente de planta</li>
          </ul>
          <a href="/arch" class="btn btn-primary">Conocer Arch</a>
        </div>
        <div class="product-showcase__preview">
          <div class="app-mockup" style="--accent: #059669;">
            <div class="app-mockup__topbar">
              <div class="app-mockup__dots"><span></span><span></span><span></span></div>
              <div class="app-mockup__url">arch.unclescompany.com</div>
            </div>
            <div class="app-mockup__body">
              <div class="app-mockup__sidebar">
                <div class="app-mockup__logo">A<span>.</span></div>
                <div class="mock-nav-item active"></div>
                <div class="mock-nav-item"></div>
                <div class="mock-nav-item"></div>
                <div class="mock-nav-item"></div>
                <div class="mock-nav-item"></div>
              </div>
              <div class="app-mockup__content">
                <div class="mock-header"></div>
                <div class="mock-kpi-row">
                  <div class="mock-kpi" style="--kpi-color: #059669;"><div class="mock-kpi__value">342</div><div class="mock-kpi__label"></div></div>
                  <div class="mock-kpi" style="--kpi-color: #10B981;"><div class="mock-kpi__value">12</div><div class="mock-kpi__label"></div></div>
                  <div class="mock-kpi" style="--kpi-color: #34D399;"><div class="mock-kpi__value">4</div><div class="mock-kpi__label"></div></div>
                </div>
                <div class="mock-chart">
                  <svg viewBox="0 0 200 60" class="mock-chart__svg">
                    <polyline points="0,50 25,42 50,45 75,35 100,20 125,30 150,22 175,10 200,15" fill="none" stroke="#059669" stroke-width="2"/>
                    <polyline points="0,50 25,42 50,45 75,35 100,20 125,30 150,22 175,10 200,15" fill="url(#archFill)" stroke="none"/>
                    <defs><linearGradient id="archFill" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#059669" stop-opacity="0.3"/><stop offset="100%" stop-color="#059669" stop-opacity="0"/></linearGradient></defs>
                  </svg>
                </div>
                <div class="mock-table">
                  <div class="mock-table__row header"></div>
                  <div class="mock-table__row"></div>
                  <div class="mock-table__row"></div>
                  <div class="mock-table__row"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Why Uncles&Co -->
  <section class="section-sm">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Por que Uncles&Co</h2>
      </div>

      <div class="grid grid-4 fade-in fade-in-delay-1">
        <div class="value-card">
          <div class="value-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h4 class="value-card__title">Compliance Ecuador nativo</h4>
          <p class="value-card__desc">IESS, SRI, MRL, NIIF. Nuestro software nace con las regulaciones ecuatorianas integradas, no adaptadas.</p>
        </div>

        <div class="value-card">
          <div class="value-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </div>
          <h4 class="value-card__title">Ecosistema integrado</h4>
          <p class="value-card__desc">HR, ERP y manufactura conectados. Comparte datos entre productos sin duplicar trabajo.</p>
        </div>

        <div class="value-card">
          <div class="value-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4c0 2 1.5 3.5 3 5l1 1 1-1c1.5-1.5 3-3 3-5a4 4 0 0 0-4-4z"/><path d="M5 20c0-3 2-5 7-5s7 2 7 5"/></svg>
          </div>
          <h4 class="value-card__title">AI incorporado</h4>
          <p class="value-card__desc">Prediccion de rotacion, asistente contable inteligente y analytics avanzados. Tecnologia de punta, aplicada.</p>
        </div>

        <div class="value-card">
          <div class="value-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h4 class="value-card__title">Soporte local</h4>
          <p class="value-card__desc">Equipo ecuatoriano que entiende tu realidad. Soporte directo, implementacion guiada, sin intermediarios.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section">
    <div class="container">
      <div class="stats fade-in">
        <div>
          <div class="stat__number">4+</div>
          <div class="stat__label">Empresas activas</div>
        </div>
        <div>
          <div class="stat__number">3</div>
          <div class="stat__label">Productos</div>
        </div>
        <div>
          <div class="stat__number">100%</div>
          <div class="stat__label">Ecuador</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Custom Solutions -->
  <section class="section-sm">
    <div class="container">
      <div class="custom-solutions fade-in">
        <div class="custom-solutions__content">
          <div class="custom-solutions__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <div>
            <h3 class="custom-solutions__title">Tu empresa no encaja en una solucion estandar?</h3>
            <p class="custom-solutions__desc">Desarrollamos software a la medida para empresas con procesos unicos. Desde integraciones con sistemas existentes hasta modulos completamente personalizados — con la misma calidad y compliance de nuestros productos.</p>
          </div>
        </div>
        <a href="/contacto" class="btn btn-secondary">Conversemos sobre tu proyecto</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-section__box fade-in">
        <h2 class="cta-section__title">Listo para digitalizar tu empresa?</h2>
        <p class="cta-section__desc">Agenda una demo personalizada y descubre como Uncles&Co puede transformar tus operaciones.</p>
        <a href="/contacto" class="btn btn-primary btn-lg">Contactanos</a>
      </div>
    </div>
  </section>

</Base>
